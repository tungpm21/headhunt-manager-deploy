# ============================================
# Headhunt Manager - Environment Variables
# ============================================
# Copy this file to .env.local and fill in values

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/headhunt_manager?schema=public"
# Optional pooled Postgres URL for production, for example Neon pooled connections
DATABASE_POOLER_URL=""

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Observability
SENTRY_DSN=""

# File Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10
