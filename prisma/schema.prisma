// Headhunt Manager + FDIWork - Database Schema
// CRM: Based on docs/crm/DESIGN.md
// FDIWork: Based on docs/fdiwork/DESIGN_FDIWORK.md

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum UserRole {
  ADMIN
  MEMBER
}

enum CandidateStatus {
  AVAILABLE
  EMPLOYED
  INTERVIEWING
  BLACKLIST
}

enum CandidateSource {
  LINKEDIN
  TOPCV
  REFERRAL
  FACEBOOK
  VIETNAMWORKS
  FDIWORK // Imported from FDIWork public website
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum CompanySize {
  SMALL
  MEDIUM
  LARGE
  ENTERPRISE
}

enum JobStatus {
  OPEN
  PAUSED
  FILLED
  CANCELLED
}

enum FeeType {
  PERCENTAGE
  FIXED
}

enum JobCandidateStage {
  SOURCED
  CONTACTED
  INTERVIEW
  OFFER
  PLACED
  REJECTED
}

enum CandidateSeniority {
  INTERN
  JUNIOR
  MID_LEVEL
  SENIOR
  LEAD
  MANAGER
  DIRECTOR
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  BLACKLISTED
}

enum JobPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum SubmissionResult {
  PENDING   // Đang trong quá trình
  HIRED     // Tuyển thành công
  REJECTED  // Bị từ chối
  WITHDRAWN // Ứng viên rút lui
}

// ==================== FDIWORK ENUMS ====================

enum EmployerStatus {
  PENDING   // Chờ admin duyệt
  ACTIVE    // Đang hoạt động
  SUSPENDED // Tạm khóa
}

enum JobPostingStatus {
  DRAFT     // Nháp, chưa gửi duyệt
  PENDING   // Chờ admin duyệt
  APPROVED  // Đã duyệt, hiển thị trên web
  REJECTED  // Admin từ chối
  EXPIRED   // Hết hạn
  PAUSED    // Employer tạm ẩn
}

enum SubscriptionTier {
  BASIC
  STANDARD
  PREMIUM
  VIP
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum ApplicationStatus {
  NEW         // Mới nộp
  REVIEWED    // Đã xem
  SHORTLISTED // Vào danh sách chọn
  REJECTED    // Không phù hợp
  IMPORTED    // Đã import vào CRM Candidate
}

// ==================== MODELS ====================

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(MEMBER)
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  createdCandidates Candidate[]     @relation("CandidateCreatedBy")
  createdClients    Client[]        @relation("ClientCreatedBy")
  createdJobOrders  JobOrder[]      @relation("JobCreatedBy")
  assignedJobOrders JobOrder[]      @relation("JobAssignedTo")
  candidateNotes    CandidateNote[]
  assignedReminders CandidateReminder[] @relation("ReminderAssignedTo")
  completedReminders CandidateReminder[] @relation("ReminderCompletedBy")
  uploadedCVs       CandidateCV[]   @relation("CVUploadedBy")
  activityLogs      ActivityLog[]
}

model Candidate {
  id              Int              @id @default(autoincrement())
  fullName        String
  phone           String?
  email           String?
  dateOfBirth     DateTime?
  gender          Gender?
  address         String?
  currentPosition String?
  currentCompany  String?
  industry        String?
  yearsOfExp      Int?
  currentSalary   Float?
  expectedSalary  Float?
  location        String?
  status          CandidateStatus    @default(AVAILABLE)
  source          CandidateSource?
  sourceDetail    String?
  level           CandidateSeniority? // Cấp bậc: Intern → Director
  skills          String[]            // PostgreSQL array, ví dụ: ["Java", "React", "SQL"]
  avatarUrl       String?
  cvFileUrl       String?
  cvFileName      String?
  isDeleted       Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Relations
  createdBy   User            @relation("CandidateCreatedBy", fields: [createdById], references: [id])
  createdById Int
  tags         CandidateTag[]
  notes        CandidateNote[]
  reminders    CandidateReminder[]
  jobLinks     JobCandidate[]
  cvFiles      CandidateCV[]
  languages    CandidateLanguage[]
  workHistory  WorkExperience[]
  applications Application[] // FDIWork: CV apply từ web public

  @@index([fullName])
  @@index([industry])
  @@index([status])
  @@index([level])
  @@index([location])
  @@index([isDeleted])
  @@index([skills], type: Gin, map: "idx_candidate_skills")
}

model Tag {
  id         Int            @id @default(autoincrement())
  name       String         @unique
  color      String         @default("#6B7280")
  candidates CandidateTag[]
}

model CandidateTag {
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId Int
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId       Int

  @@id([candidateId, tagId])
}

model CandidateNote {
  id          Int       @id @default(autoincrement())
  content     String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId Int
  createdBy   User      @relation(fields: [createdById], references: [id])
  createdById Int
  createdAt   DateTime  @default(now())
}

model CandidateReminder {
  id            Int       @id @default(autoincrement())
  title         String
  note          String?
  dueAt         DateTime
  isCompleted   Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId   Int
  assignedTo    User      @relation("ReminderAssignedTo", fields: [assignedToId], references: [id])
  assignedToId  Int
  completedBy   User?     @relation("ReminderCompletedBy", fields: [completedById], references: [id])
  completedById Int?

  @@index([candidateId, dueAt])
  @@index([assignedToId, isCompleted, dueAt])
  @@index([isCompleted, dueAt])
}

model CandidateCV {
  id           Int      @id @default(autoincrement())
  fileUrl      String
  fileName     String
  label        String?
  isPrimary    Boolean  @default(false)
  uploadedAt   DateTime @default(now())

  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId  Int
  uploadedBy   User      @relation("CVUploadedBy", fields: [uploadedById], references: [id])
  uploadedById Int

  @@index([candidateId])
}

model CandidateLanguage {
  id          Int    @id @default(autoincrement())
  language    String
  level       String?
  certificate String?

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId Int

  @@index([candidateId])
  @@index([language])
}

model WorkExperience {
  id          Int      @id @default(autoincrement())
  companyName String
  position    String
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean  @default(false)
  notes       String?

  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  candidateId Int

  @@index([candidateId])
}

model Client {
  id          Int          @id @default(autoincrement())
  companyName String
  industry    String?
  companySize CompanySize?
  address     String?
  website     String?
  notes       String?
  status      ClientStatus @default(ACTIVE) // Trạng thái khách hàng
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  createdBy   User            @relation("ClientCreatedBy", fields: [createdById], references: [id])
  createdById Int
  contacts    ClientContact[]
  employer    Employer? @relation("EmployerClient") // FDIWork: 1 Client có thể link 1 Employer
  jobOrders   JobOrder[]

  @@index([companyName])
  @@index([isDeleted])
}

model ClientContact {
  id        Int     @id @default(autoincrement())
  name      String
  position  String?
  phone     String?
  email     String?
  isPrimary Boolean @default(false)

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId Int
}

model JobOrder {
  id             Int         @id @default(autoincrement())
  title          String
  description    String?
  industry       String?     // Ngành nghề (theo spec)
  location       String?     // Địa điểm làm việc (theo spec)
  requiredSkills String[]    // Kỹ năng yêu cầu (theo spec)
  salaryMin      Float?
  salaryMax      Float?
  quantity       Int         @default(1)
  priority       JobPriority @default(MEDIUM) // Mức độ ưu tiên (theo spec)
  deadline       DateTime?
  openDate       DateTime?   // Ngày mở job (theo spec; nếu null dùng createdAt)
  status         JobStatus   @default(OPEN)
  fee            Float?
  feeType        FeeType?
  notes          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  // Relations
  client       Client         @relation(fields: [clientId], references: [id])
  clientId     Int
  assignedTo   User?          @relation("JobAssignedTo", fields: [assignedToId], references: [id])
  assignedToId Int?
  createdBy    User           @relation("JobCreatedBy", fields: [createdById], references: [id])
  createdById  Int
  candidates   JobCandidate[]
  jobPostings  JobPosting[] // FDIWork: tin tuyển dụng public link đến Job Order

  @@index([status])
  @@index([priority])
  @@index([industry])
  @@index([clientId])
  @@index([requiredSkills], type: Gin, map: "idx_job_required_skills")
}

model JobCandidate {
  id            Int                @id @default(autoincrement())
  stage         JobCandidateStage  @default(SOURCED)
  result        SubmissionResult   @default(PENDING) // Kết quả cuối cùng (theo spec)
  interviewDate DateTime?          // Ngày hẹn phỏng vấn (theo spec)
  notes         String?            // Feedback từ client / ghi chú
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  jobOrder    JobOrder  @relation(fields: [jobOrderId], references: [id], onDelete: Cascade)
  jobOrderId  Int
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  candidateId Int

  @@unique([jobOrderId, candidateId])
}

model ActivityLog {
  id         Int      @id @default(autoincrement())
  type       String
  entityType String
  entityId   Int
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([userId])
}

// ==================== FDIWORK MODELS ====================

model Employer {
  id          Int            @id @default(autoincrement())
  email       String         @unique
  password    String         // bcrypt hashed
  companyName String
  logo        String?
  description String?
  industry    String?
  companySize CompanySize?
  address     String?
  website     String?
  phone       String?
  status      EmployerStatus @default(PENDING)
  slug        String         @unique
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  // Relations
  subscription Subscription?
  jobPostings  JobPosting[]

  // Link to CRM Client (admin link thủ công)
  clientId Int?    @unique
  client   Client? @relation("EmployerClient", fields: [clientId], references: [id])

  @@index([status])
  @@index([slug])
  @@index([industry])
}

model Subscription {
  id          Int                @id @default(autoincrement())
  tier        SubscriptionTier
  status      SubscriptionStatus @default(ACTIVE)
  jobQuota    Int                // Tổng tin được đăng
  jobsUsed    Int                @default(0)
  jobDuration Int                // Số ngày tin hiển thị
  showLogo    Boolean            @default(false) // Logo ở trang chủ
  showBanner  Boolean            @default(false) // Banner slide VIP
  startDate   DateTime
  endDate     DateTime
  price       Float              // Giá gói (VND)
  createdAt   DateTime           @default(now())

  // Relations
  employer   Employer @relation(fields: [employerId], references: [id], onDelete: Cascade)
  employerId Int      @unique

  @@index([status])
  @@index([endDate])
}

model JobPosting {
  id            Int              @id @default(autoincrement())
  title         String
  slug          String           @unique
  description   String
  requirements  String?
  benefits      String?
  salaryMin     Float?
  salaryMax     Float?
  salaryDisplay String?          // "15-20 triệu" hoặc "Thỏa thuận"
  industry      String?
  position      String?          // Cấp bậc: Nhân viên, Trưởng phòng...
  location      String?
  workType      String?          // Full-time, Part-time, Remote
  quantity      Int              @default(1)
  skills        String[]         @default([]) // Danh sách kỹ năng
  status        JobPostingStatus @default(DRAFT)
  rejectReason  String?          // Admin điền khi reject
  publishedAt   DateTime?
  expiresAt     DateTime?
  viewCount     Int              @default(0)
  applyCount    Int              @default(0)
  isFeatured    Boolean          @default(false) // VIP
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // Relations
  employer   Employer @relation(fields: [employerId], references: [id])
  employerId Int

  applications Application[]

  // Link to CRM JobOrder (admin link thủ công)
  jobOrder   JobOrder? @relation(fields: [jobOrderId], references: [id])
  jobOrderId Int?

  @@index([status])
  @@index([industry])
  @@index([location])
  @@index([slug])
  @@index([employerId])
  @@index([expiresAt])
}

model Application {
  id          Int               @id @default(autoincrement())
  fullName    String
  email       String
  phone       String?
  coverLetter String?
  cvFileUrl   String?
  cvFileName  String?
  status      ApplicationStatus @default(NEW)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  // Relations
  jobPosting   JobPosting @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  jobPostingId Int

  // Link to CRM Candidate (sau khi import)
  candidate   Candidate? @relation(fields: [candidateId], references: [id])
  candidateId Int?

  @@index([jobPostingId])
  @@index([status])
  @@index([email])
  @@unique([jobPostingId, email])
}
